      "description": "Pay-per-call access to list_tables"
    },
    {
      "path": "/execute_sql",
      "price": "0.01",
      "description": "Pay-per-call access to execute_sql"
    },
    {
      "path": "/apply_migration",
      "price": "0.01",
      "description": "Pay-per-call access to apply_migration"
    },
    {
      "path": "/get_logs",
      "price": "0.01",
      "description": "Pay-per-call access to get_logs"
    },
    {
      "path": "/get_advisors",
      "price": "0.01",
      "description": "Pay-per-call access to get_advisors"
    },
    {
      "path": "/deploy_edge_function",
      "price": "0.01",
      "description": "Pay-per-call access to deploy_edge_function"
