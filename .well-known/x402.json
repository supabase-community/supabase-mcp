{
  "name": "supabase-community/supabase-mcp",
  "description": "MCP server for interacting with Supabase",
  "accepts": [
    {
      "network": "eip155:8453",
      "asset": "USDC",
      "address": "YOUR_WALLET_ADDRESS"
    }
  ],
  "resources": [
    {
      "path": "/list_projects",
      "price": "0.01",
      "description": "Pay-per-call access to list_projects"
